# hermes-paperclip-on-hostinger — environment template.
# Copy to .env then run ./setup.sh to fill the secret-bearing lines.
# Detailed explanation lives in README.md and docs/EXPOSURE-*.md so
# this file stays minimal — some env parsers treat lines containing
# colons or arrows in comments as malformed entries.

COMPOSE_PROJECT_NAME=hermes-paperclip

# Overlay selector. setup.sh writes one of:
#   docker-compose.yml docker-compose.local.yml
#   docker-compose.yml docker-compose.tailscale.yml
#   docker-compose.yml docker-compose.traefik.yml
#   docker-compose.yml docker-compose.cloudflared.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# Public DNS suffix (only used by traefik and cloudflared modes).
PROJECT_DOMAIN=

# Admin credentials shared by Hermes ttyd basic-auth and Paperclip sign-up.
ADMIN_USERNAME=hermes
ADMIN_NAME=Dante
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Paperclip public-facing URL. setup.sh writes the right value per mode.
PAPERCLIP_PUBLIC_URL=

# Tailscale mode. Generate an auth key in the Tailscale admin console
# under Settings then Keys. The sidecar registers as
# TS_HOSTNAME.TAILNET.ts.net (visible in the admin console).
TS_AUTHKEY=
TS_HOSTNAME=hermes-paperclip
