# ─────────────────────────────────────────────────────────────
# hermes-paperclip-on-hostinger — environment template
# Copy to `.env`. `setup.sh` fills the secret-bearing lines.
# ─────────────────────────────────────────────────────────────

# Compose: project name (used as service prefix + Docker network name)
COMPOSE_PROJECT_NAME=hermes-paperclip

# Compose: which overlay file(s) to layer on top of the base.
# `setup.sh` sets this based on the mode you choose. Examples:
#   docker-compose.yml:docker-compose.local.yml
#   docker-compose.yml:docker-compose.traefik.yml
#   docker-compose.yml:docker-compose.cloudflared.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# Public DNS suffix. Required for traefik and cloudflared modes.
# tui.${PROJECT_DOMAIN}, dash.${PROJECT_DOMAIN}, paperclip.${PROJECT_DOMAIN}
# In local mode this is unused but Paperclip's PUBLIC_URL still wants
# something well-formed; setup.sh sets it to localhost there.
PROJECT_DOMAIN=

# Admin credentials. Shared between:
#   - Hermes ttyd basic-auth (username/password directly)
#   - Paperclip bootstrap sign-up (email/password)
ADMIN_USERNAME=hermes
ADMIN_NAME=Dante
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Paperclip public-facing URL. Set by setup.sh to:
#   local mode      → http://localhost:3100
#   tailscale mode  → https://<TS_HOSTNAME>.<your-tailnet>.ts.net:3100
#   traefik mode    → https://paperclip.${PROJECT_DOMAIN}
#   cloudflared     → https://paperclip.${PROJECT_DOMAIN}
PAPERCLIP_PUBLIC_URL=

# ─────────────────────────────────────────────────────────────
# Tailscale mode only — sidecar joins your tailnet as a mesh node.
# Generate an auth key at:
#   https://login.tailscale.com/admin/settings/keys
# Reusable + expiry = your call. The sidecar will register as
# <TS_HOSTNAME>.<your-tailnet>.ts.net (visible in the admin console).
TS_AUTHKEY=
TS_HOSTNAME=hermes-paperclip
